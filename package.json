{
  "name": "liquibase",
  "displayName": "Liquibase",
  "description": "execute liquibase changelogs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "liquibase.createLiquibaseConfiguration",
        "title": "Create Liquibase Configuration",
        "category": "Liquibase"
      },
      {
        "command": "liquibase.editExistingLiquibaseConfiguration",
        "title": "Edit existing Liquibase Configuration",
        "category": "Liquibase"
      },
      {
        "command": "liquibase.addExistingConfiguration",
        "title": "Add existing liquibase.properties to the configuration",
        "category": "Liquibase"
      },
      {
        "command": "liquibase.testConfiguration",
        "title": "Tests an existing liquibase configuration",
        "category": "Liquibase"
      },
      {
        "command": "liquibase.removeExistingConfiguration",
        "title": "Remove existing liquibase.properties from the configuration",
        "category": "Liquibase"
      }
    ],
    "configuration": {
      "title": "Liquibase",
      "properties": {
        "liquibase.configurationPath": {
          "type": "string",
          "default": "data/liquibase",
          "markdownDescription": "Relative path inside the workspace where liquibase configuration should be stored.\nThis folder should not be included in your version control system."
        },
        "liquibase.liquibaseFolder": {
          "type": "string",
          "markdownDescription": "Relative path inside the workspace, where your liquibase changelog files are located.This location will be added the the classpath of newly generated files.\n\nIf there is no path given, then the project itself will be added to classpath."
        },
        "liquibase.driverLocation": {
          "type": "string",
          "markdownDescription": "The location where this extension should download all the drivers and necessary jar files.\n\nOn Windows, backslashes must be escaped, e.g. `C:\\\\dev\\\\myDrivers`."
        },
        "liquibase.defaultDatabaseForConfiguration": {
          "type": "string",
          "markdownDescription": "The default selected database for creating a new configuration.",
          "enum": [
            "NO_PRE_CONFIGURED_DRIVER",
            "MARIADB",
            "MYSQL",
            "MSSQL",
            "POSTGRESQL",
            "ORACLE"
          ],
          "enumItemLabels": [
            "no pre-configured driver",
            "MariaDB",
            "MySQL",
            "MS SQL",
            "PostgreSQL",
            "Oracle"
          ],
          "default": "NO_PRE_CONFIGURED_DRIVER"
        }
      }
    },
    "submenus": [
      {
        "id": "liquibase.configurationMenu",
        "label": "Liquibase"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "liquibase.configurationMenu",
          "when": "resourceLangId == properties"
        }
      ],
      "editor/context": [
        {
          "submenu": "liquibase.configurationMenu",
          "when": "resourceLangId == properties"
        }
      ],
      "liquibase.configurationMenu": [
        {
          "command": "liquibase.editExistingLiquibaseConfiguration",
          "when": "resourceLangId == properties"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "postinstall": "cd webview-ui && npm install && npm run build"
  },
  "devDependencies": {
    "@types/download": "^8.0.5",
    "@types/mocha": "^10.0.6",
    "@types/node": "20.x",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "download": "^8.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-tsdoc": "^0.2.17",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "download": "^8.0.0",
    "immer": "^10.0.3",
    "properties-file": "^3.3.15",
    "use-immer": "^0.9.0"
  }
}
