{
  "name": "liquibase",
  "displayName": "Liquibase",
  "description": "execute liquibase changelogs",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "Liquibase.update",
        "title": "Liquibase Update"
      },
      {
        "command": "Liquibase.drop-all",
        "title": "Liquibase Drop-all"
      },
      {
        "command": "Liquibase.validate",
        "title": "Liquibase Validate"
      },
      {
        "command": "Liquibase.status",
        "title": "Liquibase Status"
      },
      {
        "command": "Liquibase.diff",
        "title": "Liquibase Diff"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "dependencies": {
    "download": "^8.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.84.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "download": "^8.0.0",
    "typescript": "^5.3.2",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.8"
  }
}
