    <insert tableName="PROJECTTICKET">
      <column name="CREATOR" value="c7ddf982-0e58-4152-b82b-8f5673b0b729"/>
      <column name="SUBJECT" value="Erzeugen von Leistungsnachweisen"/>
      <column name="DESCRIPTION" value="&lt;p&gt;&lt;strong&gt;Wer ist der Nutzer/Anwender?&lt;/strong&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;Budget-Verantwortliche, Controller&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Was ist der Wunsch/Ziel?&lt;/strong&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;Leistungsnachweise können erzeugt werden. Diese enthalten geprüfte, jedoch noch nicht abgerechnete Zeitbuchungen.&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Was ist der Grund/Nutzen/Schmerz?&lt;/strong&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;Kunden möchten vor Rechnungsstellung die Zeiten gegenprüfen. Hierzu wird ein entsprechender Nachweis benötigt&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Weitere Informationen (Mockup)?&lt;/strong&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Akzeptanzkriterien:&lt;/strong&gt;&amp;nbsp;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;neuer Button “Leistungsnachweis” im Reiter “Zeitbuchungen” innerhalb eines Projektes&lt;/li&gt;&lt;li&gt;bei Klick wird ein Report mit allen Zeiten erzeugt, die selektiert wurden&lt;/li&gt;&lt;li&gt;Report öffnet sich in neuen Tab mit tabellarischer Auflistung der Zeiten, des dazugehörigen Ticket-Titels und Ticket-Nr&lt;/li&gt;&lt;/ul&gt;"/>
      <column name="PRIORITY" value="Medium"/>
      <column name="USER_NEW" value="Admin"/>
      <column name="DATE_NEW" valueDate="2023-07-08T09:54:56"/>
      <column name="REQUESTER_CONTACT_ID" value="c7ddf982-0e58-4152-b82b-8f5673b0b729"/>
