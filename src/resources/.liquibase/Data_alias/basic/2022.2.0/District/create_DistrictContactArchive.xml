<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="b.ulrich" id="d5f7e0c8-17f3-4757-8a77-567d99e26866">
        <createTable tableName="DISTRICTCONTACTARCHIVE">
            <column name="DISTRICTCONTACTARCHIVEID" type="CHAR(36)">
                <constraints primaryKey="true" primaryKeyName="PK_DISTRICTCONTACTARCHIVE_DISTRICTCONTACTARCHIVEID"/>
            </column>
            <column name="CONTACT_ID" type="CHAR(36)"/>
            <column name="DISTRICT_ID" type="CHAR(36)"/>
            <column name="ADVISER_CONTACT_ID" type="CHAR(36)"/>
            <column name="DISTRICTRESPONSIBLE_ID" type="CHAR(36)"/>
            <column name="ADVISER_ROLE" type="VARCHAR(36)"/>
            <column name="STATUS" type="VARCHAR(36)"/>
            <column name="VISITFREQUENCY" type="VARCHAR(36)"/>
            <column name="VALID_FROM" type="DATETIME"/>
            <column name="VALID_UNTIL" type="DATETIME"/>
            <column name="ORIGIN" type="VARCHAR(36)"/>
            <column name="VISIT_STARTDATE" type="DATETIME"/>
            <column name="VISIT_BEGIN_TIME" type="TIME"/>
            <column name="VISIT_END_TIME" type="TIME"/>
            <column name="RULE_ACTIVE" type="TINYINT"/>
            
            <column name="USER_NEW" type="NVARCHAR(50)" />
            <column name="DATE_NEW" type="DATETIME" />
            <column name="USER_EDIT" type="NVARCHAR(50)" />
            <column name="DATE_EDIT" type="DATETIME" />
        </createTable>
        
        <addNotNullConstraint tableName="DISTRICTCONTACTARCHIVE" columnName="DISTRICT_ID" columnDataType="CHAR(36)"/>
        <addNotNullConstraint tableName="DISTRICTCONTACTARCHIVE" columnName="CONTACT_ID" columnDataType="CHAR(36)"/>
        <addNotNullConstraint tableName="DISTRICTCONTACTARCHIVE" columnName="DISTRICTRESPONSIBLE_ID" columnDataType="CHAR(36)"/>
        
        <createIndex tableName="DISTRICTCONTACTARCHIVE" indexName="IDX_DISTRCTCNTCTARCHIVE_CONTACT_ID">
            <column name="CONTACT_ID"/>
        </createIndex>
        <createIndex tableName="DISTRICTCONTACTARCHIVE" indexName="IDX_DISTRCTCNTCTARCHIVE_DISTRICT_ID">
            <column name="DISTRICT_ID"/>
        </createIndex>
        <createIndex tableName="DISTRICTCONTACTARCHIVE" indexName="IDX_DISTRCTCNTCTARCHIVE_DSTRCTRSP_ID">
            <column name="DISTRICTRESPONSIBLE_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>