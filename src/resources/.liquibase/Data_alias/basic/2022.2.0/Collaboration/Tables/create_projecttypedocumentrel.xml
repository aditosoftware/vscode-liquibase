<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="M.Wachsmuth" id="e9435f4b-c654-402a-8e82-065de053da2a">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="PROJECTTYPEDOCUMENTREL" />
      </not>
    </preConditions>
    <createTable tableName="PROJECTTYPEDOCUMENTREL">
      <column name="DOCUMENTTEMPLATE_ID" type="CHAR(36)" />
      <column defaultValueComputed="NULL" name="DATE_EDIT" type="datetime" />
      <column name="PROJECTTYPEDOCUMENTRELID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
      <column name="PROJECTTICKETTYPE_ID" type="CHAR(36)" />
      <column name="PROJECTTYPE_ID" type="CHAR(36)" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
    </createTable>
  </changeSet>
  <changeSet author="M.Wachsmuth" id="f17f6b28-d6ec-4d91-b30b-3daf96fa040c">
      <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="PROJECTTICKETTYPE_ID_IDX"/>
            </not>
      </preConditions>
    <createIndex indexName="PROJECTTICKETTYPE_ID_IDX" tableName="PROJECTTYPEDOCUMENTREL">
      <column name="PROJECTTICKETTYPE_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="M.Wachsmuth" id="dcfd8a2f-2c99-423c-9d24-a6b50b7334a3">
      <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="PRJTYPEDOCREL_PRJTYPE_ID_IDX"/>
            </not>
      </preConditions>
    <createIndex indexName="PRJTYPEDOCREL_PRJTYPE_ID_IDX" tableName="PROJECTTYPEDOCUMENTREL">
      <column name="PROJECTTYPE_ID" />
    </createIndex>
  </changeSet>
</databaseChangeLog>