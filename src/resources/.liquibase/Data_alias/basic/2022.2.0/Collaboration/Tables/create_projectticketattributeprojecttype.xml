<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="M.Wachsmuth" id="bcd30207-19a7-4c56-ba99-4c50e32d8b58">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="PROJECTTICKETATTRIBUTEPROJECTTYPE" />
      </not>
    </preConditions>
    <createTable tableName="PROJECTTICKETATTRIBUTEPROJECTTYPE">
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
      <column name="DATE_EDIT" type="datetime" />
      <column name="PROJECTTICKETATTRIBUTE_ID" type="CHAR(36)" />
      <column name="PROJECTTYPE_ID" type="CHAR(36)" />
      <column name="PROJECTTICKETATTRIBUTEPROJECTTYPEID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
    </createTable>
  </changeSet>
  <changeSet author="M.Wachsmuth" id="0c7ab486-cfb8-4ff3-b9b7-a91d21761126">
    <createIndex indexName="PROJATTRTYP_PROJTTATTRE_ID_IDX" tableName="PROJECTTICKETATTRIBUTEPROJECTTYPE">
      <column name="PROJECTTICKETATTRIBUTE_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="M.Wachsmuth" id="5e31afbe-a072-40a7-a972-3a7fa30a1a75">
    <createIndex indexName="PRJTATTRPRJTYP_PROJTYPE_ID_IDX" tableName="PROJECTTICKETATTRIBUTEPROJECTTYPE">
      <column name="PROJECTTYPE_ID" />
    </createIndex>
  </changeSet>
</databaseChangeLog>

