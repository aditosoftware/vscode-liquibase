<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
  <changeSet author="A.Voegl" id="6bb48b47-64d1-4fa3-8293-c21031c76d09">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="PROJECTPERMISSION" />
      </not>
    </preConditions>
    <createTable tableName="PROJECTPERMISSION">
      <column defaultValueComputed="NULL" name="CONTROLE_TIME" type="TINYINT" />
      <column defaultValueComputed="NULL" name="DATE_EDIT" type="datetime" />
      <column name="PROJECTPERMISSIONID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column defaultValueComputed="NULL" name="EDIT_PROJECTTICKET_COMMENT" type="TINYINT" />
      <column defaultValueComputed="NULL" name="DELETE_PROJECTTICKET" type="TINYINT" />
      <column defaultValueComputed="NULL" name="READ_PROJECTTICKET" type="TINYINT" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
      <column name="ROLE" type="VARCHAR(150)" />
      <column defaultValueComputed="NULL" name="READ_PROJECTTICKET_COMMENT" type="TINYINT" />
      <column defaultValueComputed="NULL" name="EDIT_PROJECTTICKET" type="TINYINT" />
      <column defaultValueComputed="NULL" name="DELETE_PROJECTTICKET_COMMENT" type="TINYINT" />
      <column defaultValueComputed="NULL" name="EDIT_PROJECT" type="TINYINT" />
      <column defaultValueComputed="NULL" name="DELETE_PROJECT" type="TINYINT" />
      <column defaultValueComputed="NULL" name="MOVE_PROJECTTICKET" type="TINYINT" />
      <column name="PROJECTTYPE_ID" type="CHAR(36)" />
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
      <column defaultValueComputed="NULL" name="CREATE_PROJECTTICKET" type="TINYINT" />
      <column defaultValueComputed="NULL" name="CREATE_PROJECTTICKET_COMMENT" type="TINYINT" />
      <column defaultValueComputed="NULL" name="READ_PROJECT" type="TINYINT" />
      <column name="READ_PROJECTTICKET_FILTER" type="VARCHAR(512)" />
    </createTable>
  </changeSet>
  <changeSet author="A.Voegl" id="d55ce0c9-2982-476a-be13-8c635dca8028">
      <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="PRJCTPERMISION_PRJCTTYP_ID_IDX"/>
            </not>
      </preConditions>
    <createIndex indexName="PRJCTPERMISION_PRJCTTYP_ID_IDX" tableName="PROJECTPERMISSION">
      <column name="PROJECTTYPE_ID" />
    </createIndex>
  </changeSet>
</databaseChangeLog>
