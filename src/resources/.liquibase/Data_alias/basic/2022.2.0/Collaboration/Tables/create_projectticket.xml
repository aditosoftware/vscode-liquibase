<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
  <changeSet author="A.Voegl" id="bbf5ebb2-f317-477c-b75b-a17af71caea0">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="PROJECTTICKET" />
      </not>
    </preConditions>
    <createTable tableName="PROJECTTICKET">
      <column defaultValueComputed="NULL" name="OFFEREDHOURS" type="DECIMAL(10, 2)" />
      <column defaultValueComputed="NULL" name="DATE_EDIT" type="datetime" />
      <column name="PRIORITY" type="VARCHAR(50)" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
      <column name="STATUS" type="VARCHAR(50)" />
      <column name="DESCRIPTION" type="LONGTEXT" />
      <column name="PROJECTTICKETID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column defaultValueComputed="NULL" name="DATE_DUE" type="date" />
      <column name="PROGRESS" type="VARCHAR(50)" />
      <column name="EDITOR_CONTACT_ID" type="CHAR(36)" />
      <column defaultValueComputed="NULL" name="DATE_START" type="date" />
      <column name="SUBJECT" type="VARCHAR(250)" />
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
      <column defaultValueComputed="NULL" name="PLANNEDHOURS" type="DECIMAL(10, 2)" />
      <column name="PROJECT_ID" type="CHAR(36)" />
      <column name="REQUESTER_CONTACT_ID" type="CHAR(36)" />
      <column defaultValueComputed="NULL" name="ticketnumber" type="INT" />
      <column name="TICKETTYPE_ID" type="CHAR(36)" />
      <column name="CREATOR" type="CHAR(36)" />
      <column name="PROJECTTYPESTATUSREASON_ID" type="CHAR(36)" />
      <column defaultValueComputed="NULL" name="COMPLETED" type="date" />
    </createTable>
  </changeSet>
  <changeSet author="A.Voegl" id="af8026ae-3747-4187-837f-7f92e0c7ac20">
    <createIndex indexName="TICKETTYPE_ID_IDX" tableName="PROJECTTICKET">
      <column name="TICKETTYPE_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="A.Voegl" id="4be1c321-8623-414c-964a-fa9a88b763d1">
    <createIndex indexName="projectticket_idx_EDITOR_CONTACT_ID" tableName="PROJECTTICKET">
      <column name="EDITOR_CONTACT_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="A.Voegl" id="817cf5fd-2d2d-47f1-9f5f-786a368f66be">
    <createIndex indexName="projectticket_idx_PROJECT_ID" tableName="PROJECTTICKET">
      <column name="PROJECT_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="A.Voegl" id="ef068779-5516-45c7-b58f-c06f50f92c16">
    <createIndex indexName="projectticket_idx_REQUESTER_CONTACT_ID" tableName="PROJECTTICKET">
      <column name="REQUESTER_CONTACT_ID" />
    </createIndex>
  </changeSet>
</databaseChangeLog>
