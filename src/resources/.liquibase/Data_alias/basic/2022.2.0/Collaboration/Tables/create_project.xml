<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
  <changeSet author="A.Voegl" id="4c23cd22-242c-4025-b825-46727440845c">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="PROJECT" />
      </not>
    </preConditions>
    <createTable tableName="PROJECT">
      <column name="STATUS" type="VARCHAR(50)" />
      <column defaultValueComputed="NULL" name="DATE_EDIT" type="datetime" />
      <column name="DESCRIPTION" type="LONGTEXT" />
      <column name="PROJECTID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column name="CONTACT_ID" type="CHAR(36)" />
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
      <column name="NAME" type="VARCHAR(100)" />
      <column name="PROJECTTYPE_ID" type="CHAR(36)" />
      <column name="PROTECTED" type="CHAR(1)" />
      <column defaultValueComputed="NULL" name="BILLABLE" type="TINYINT" />
      <column defaultValueComputed="NULL" name="PICTURE" type="LONGBLOB" />
      <column name="BILLINGDESCRIPTION" type="LONGTEXT" />
    </createTable>
  </changeSet>
  <changeSet author="A.Voegl" id="54bb0115-ae9c-4698-8965-9dc7b23615aa">
    <createIndex indexName="project_idx_CONTACT_ID" tableName="PROJECT">
      <column name="CONTACT_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="A.Voegl" id="00e98a6e-aa1d-42b5-a059-55d8e918d0fe">
    <createIndex indexName="project_idx_PROJECTTYPE_ID" tableName="PROJECT">
      <column name="PROJECTTYPE_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="A.Voegl" id="c7cb405e-638b-404e-80d7-452dbc3f9b4c">
    <createIndex indexName="project_idx_user_new" tableName="PROJECT">
      <column name="USER_NEW" />
    </createIndex>
  </changeSet>
</databaseChangeLog>
