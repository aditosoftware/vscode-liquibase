<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="b.ulrich" id="344b84d0-e61f-4a5a-a1d3-46bac1b89cad">
        <preConditions onFail="MARK_RAN">
            <not>
              <tableExists tableName="RESOURCEOPERATIONTASK"/>
            </not>
        </preConditions>
        <createTable tableName="RESOURCEOPERATIONTASK">
            <column name="RESOURCEOPERATIONTASKID" type="CHAR(36)">
                <constraints primaryKey="true" primaryKeyName="PK_RESOURCEOPERATIONTASKID"/>
            </column>
            <column name="SUBJECT" type="NVARCHAR(150)"/>
            <column name="DESCRIPTION" type="NCLOB"/>
            <column name="PRIORITY" type="VARCHAR(36)"/>
            <column name="STATUS" type="VARCHAR(36)"/>
            <column name="TIME_ESTIMATED" type="INTEGER"/>
            <column name="RESOURCEOPERATION_ID" type="CHAR(36)"/>
            <column name="RESOURCEOPERATIONTASKTEMPLATE_ID" type="CHAR(36)"/>
            <column name="RESOURCECAMPAIGN_ID" type="CHAR(36)"/>
            <column name="OPTIONAL" type="TINYINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="ISSERIAL" type="TINYINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="ORGANISATION_CONTACT_ID" type="CHAR(36)"/>
            <column name="PERSON_CONTACT_ID" type="CHAR(36)"/>
            <column name="PARENT_ID" type="CHAR(36)"/>
            <column name="KIND" type="VARCHAR(36)"/>
            <column name="PROGRESS" type="CHAR(36)"/>
            <column name="OBJECT_TYPE" type="NVARCHAR(63)"/>
            <column name="OBJECT_ROWID" type="CHAR(36)"/>
            <column name="DUE_DATE" type="DATETIME"/>
            <column name="SORTING_LAYER" type="INTEGER"/>
            <column name="SORTING_VALUE" type="INTEGER"/>
            
            <column name="USER_NEW" type="NVARCHAR(50)"/>
            <column name="DATE_NEW" type="DATETIME"/>
            <column name="USER_EDIT" type="NVARCHAR(50)"/>
            <column name="DATE_EDIT" type="DATETIME"/>
        </createTable>
        
        <createIndex tableName="RESOURCEOPERATIONTASK" indexName="IDX_RESORCOPRNTSK_OPERATION_ID">
            <column name="RESOURCEOPERATION_ID"/>
        </createIndex>
        <createIndex tableName="RESOURCEOPERATIONTASK" indexName="IDX_RESOURCOPRNTSK_CAMPAIGN_ID">
            <column name="RESOURCECAMPAIGN_ID"/>
        </createIndex>
        <createIndex tableName="RESOURCEOPERATIONTASK" indexName="IDX_RESORCOPRNTSK_ORGCONTCT_ID">
            <column name="ORGANISATION_CONTACT_ID"/>
        </createIndex>
        <createIndex tableName="RESOURCEOPERATIONTASK" indexName="IDX_RESORCOPRNTSK_PERSONTCT_ID">
            <column name="PERSON_CONTACT_ID"/>
        </createIndex>
        <createIndex tableName="RESOURCEOPERATIONTASK" indexName="IDX_RESOURCEOPERNTASK_OBJ_TYPE">
            <column name="OBJECT_TYPE"/>
        </createIndex>
        <createIndex tableName="RESOURCEOPERATIONTASK" indexName="IDX_RESOURCOPERNTASK_OBJ_ROWID">
            <column name="OBJECT_ROWID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>