<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="b.ulrich" id="8fe776b6-1fe0-4977-8fa6-d830e1152b39">
        <preConditions onFail="MARK_RAN">
            <not>
              <tableExists tableName="RESOURCEOPERATIONTASK"/>
            </not>
        </preConditions>
        <createTable tableName="RESOURCEOPERATION">
            <column name="RESOURCEOPERATIONID" type="CHAR(36)">
                <constraints primaryKey="true" primaryKeyName="PK_RESOURCEOPERATIONID"/>
            </column>
            <column name="RESOURCEOPERATIONNUMBER" type="BIGINT"/>
            <column name="TITLE" type="NVARCHAR(150)"/>
            <column name="DESCRIPTION" type="NCLOB"/>
            <column name="DATE_BEGIN" type="DATETIME"/>
            <column name="DATE_END" type="DATETIME"/>
            <column name="STATUS" type="VARCHAR(36)"/>
            <column name="KIND" type="VARCHAR(36)"/>
            <column name="PRIORITY" type="VARCHAR(36)"/>
            <column name="ORGANISATION_CONTACT_ID" type="CHAR(36)"/>
            <column name="PERSON_CONTACT_ID" type="CHAR(36)"/>
            <column name="COLOR" type="VARCHAR(100)"/>
            
            <column name="USER_NEW" type="NVARCHAR(50)"/>
            <column name="DATE_NEW" type="DATETIME"/>
            <column name="USER_EDIT" type="NVARCHAR(50)"/>
            <column name="DATE_EDIT" type="DATETIME"/>
        </createTable>

        <createIndex tableName="RESOURCEOPERATION" indexName="IDX_RESOURCEOPERATN_CONTACT_ID">
            <column name="ORGANISATION_CONTACT_ID"/>
        </createIndex>
        <createIndex tableName="RESOURCEOPERATION" indexName="IDX_RESOURCEOPER_PERSCNTACT_ID">
            <column name="PERSON_CONTACT_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>