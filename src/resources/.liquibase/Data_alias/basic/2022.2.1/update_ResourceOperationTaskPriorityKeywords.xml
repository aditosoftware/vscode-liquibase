<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="b.ulrich" id="65771bec-247b-4505-8345-f39bd8c041ae"> 
        <!--change keywords so they are consistent with task priorities-->
        
        <!--very high-->
        <delete tableName="AB_KEYWORD_ENTRY">
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = '15e18ade-4689-49e6-986e-562c676cb140'</where>
        </delete>
        <!--critical-->
        <delete tableName="AB_KEYWORD_ENTRY">
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = '8a802f36-b099-499c-ac19-f8791fe76f02'</where>
        </delete>
        
        <update tableName="AB_KEYWORD_ENTRY">
            <column name="TITLE" value="{$TASK_PRIORITY_LOW}"/>
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = 'bc8795dd-8d87-4559-a92c-8146c13fa28c'</where>
        </update>
        <update tableName="AB_KEYWORD_ENTRY">
            <column name="TITLE" value="{$TASK_PRIORITY_NORMAL}"/>
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = '0be0e9fd-43d8-4e41-90ce-56b41b3978cc'</where>
        </update>
        <update tableName="AB_KEYWORD_ENTRY">
            <column name="TITLE" value="{$TASK_PRIORITY_HIGH}"/>
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = '0007717d-0c00-4508-878c-8e5ca4fb7d55'</where>
        </update>
        
        <insert tableName="AB_KEYWORD_ENTRY">
            <column name="AB_KEYWORD_ENTRYID" value="bd901a7e-e60e-4cc2-a059-b64363348db5"/>
            <column name="KEYID" value="NONE"/>
            <column name="TITLE" value="{$TASK_PRIORITY_NONE}"/>
            <column name="CONTAINER" value="ResourceOperationTaskPriority"/>
            <column name="AB_KEYWORD_CATEGORY_ID" value="b873585b-ec31-4b90-885d-793e8abca0fd"/>
            <column name="SORTING" valueNumeric="0"/>
            <column name="ISACTIVE" valueNumeric="1"/>
            <column name="ISESSENTIAL" valueNumeric="1"/>
        </insert>
  </changeSet>
</databaseChangeLog>