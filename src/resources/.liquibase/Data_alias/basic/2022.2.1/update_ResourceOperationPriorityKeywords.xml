<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="b.ulrich" id="65771bec-247b-4505-8345-f39bd8c041ae"> 
        <!--change keywords so they are consistent with task priorities-->
        
        <!--very high-->
        <delete tableName="AB_KEYWORD_ENTRY">
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = '000a45cf-271d-4ad7-8b28-ac2924f02ffa'</where>
        </delete>
        <!--critical-->
        <delete tableName="AB_KEYWORD_ENTRY">
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = 'a577d37c-5016-4170-8bfa-dd9b354d44af'</where>
        </delete>
        
        <update tableName="AB_KEYWORD_ENTRY">
            <column name="TITLE" value="{$TASK_PRIORITY_LOW}"/>
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = 'da0b8135-f7a3-4c08-bbc1-dc5e935099d0'</where>
        </update>
        <update tableName="AB_KEYWORD_ENTRY">
            <column name="TITLE" value="{$TASK_PRIORITY_NORMAL}"/>
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = 'e95d89d0-3c17-4739-ab1a-92f10483e29a'</where>
        </update>
        <update tableName="AB_KEYWORD_ENTRY">
            <column name="TITLE" value="{$TASK_PRIORITY_HIGH}"/>
            <where>AB_KEYWORD_ENTRY.AB_KEYWORD_ENTRYID = '5ca97f75-1e8d-4f8b-a139-6203a8115241'</where>
        </update>
        
        <insert tableName="AB_KEYWORD_ENTRY">
            <column name="AB_KEYWORD_ENTRYID" value="792f9d83-ffe3-4f42-8263-b1c7c1971088"/>
            <column name="KEYID" value="NONE"/>
            <column name="TITLE" value="{$TASK_PRIORITY_NONE}"/>
            <column name="CONTAINER" value="ResourceOperationPriority"/>
            <column name="AB_KEYWORD_CATEGORY_ID" value="55db726a-02d8-48aa-97c4-b87f60ed7ed1"/>
            <column name="SORTING" valueNumeric="0"/>
            <column name="ISACTIVE" valueNumeric="1"/>
            <column name="ISESSENTIAL" valueNumeric="1"/>
        </insert>
  </changeSet>
</databaseChangeLog>