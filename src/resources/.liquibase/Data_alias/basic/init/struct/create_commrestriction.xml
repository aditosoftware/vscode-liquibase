<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="s.leierseder" id="b4c37abb-8d02-4fcf-a585-64e61864ece6">
      <preConditions onFail="MARK_RAN">
        <not>
          <tableExists tableName="COMMRESTRICTION"/>
        </not>
      </preConditions>
        <createTable tableName="COMMRESTRICTION">
            <column name="COMMRESTRICTIONID" type="CHAR(36)">
                <constraints primaryKey="true"/>
            </column>
            <column name="MEDIUM" type="VARCHAR(36)"/>
            <column name="REASON" type="NVARCHAR(250)"/>
            <column name="CONTACT_ID" type="CHAR(36)"/>
            <column name="STARTDATE" type="DATETIME"/>
            <column name="EMPLOYEE_INVOLVED" type="NVARCHAR(250)"/>
        </createTable>
    </changeSet>
</databaseChangeLog>