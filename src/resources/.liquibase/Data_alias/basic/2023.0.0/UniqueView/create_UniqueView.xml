<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="v.broens" id="959f5a67-7b80-40da-9161-9168e0dcf33c">
    <createTable  tableName="UNIQUEVIEW">
        <column name="UNIQUEVIEWID" type="CHAR(36)">
            <constraints primaryKey = "true" nullable = "false"/>
        </column>
        <column name="CONTACT_ID" type="CHAR(36))"/>
        <column name="OBJECT_ROWID" type="CHAR(36)"/>
        <column name="OBJECT_TYPE" type="NVARCHAR(63)"/>
        <column name="USER_NEW" type="NVARCHAR(50)">
                <constraints nullable="false"/>
        </column> 
        <column name="DATE_NEW" type="DATETIME">
            <constraints nullable="false"/>
        </column>
        <column name="USER_EDIT" type="NVARCHAR(50)" />
        <column name="DATE_EDIT" type="DATETIME" />
    </createTable>
    
    <createIndex indexName="IDX_UNIQUEVIEW_CONTACT_ID" tableName="UNIQUEVIEW">
            <column name="CONTACT_ID"/>
    </createIndex>
    <createIndex indexName="IDX_UNIQUEVIEW_OBJECT_ROWID" tableName="UNIQUEVIEW">
            <column name="OBJECT_ROWID"/>
    </createIndex>
    <createIndex indexName="IDX_UNIQUEVIEW_OBJECT_TYPE" tableName="UNIQUEVIEW">
            <column name="OBJECT_TYPE"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>