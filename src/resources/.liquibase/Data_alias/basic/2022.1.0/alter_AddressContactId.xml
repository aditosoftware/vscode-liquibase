<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="t.kerscher" id="033a9d71-2da1-4c5a-83c4-199a800e57db">
        <addColumn tableName="ADDRESS">
            <column name="OBJECT_ROWID" type="CHAR(36)"/>
            <column name="OBJECT_TYPE" type="VARCHAR(63)"/>
	</addColumn>
        <sql>
            UPDATE ADDRESS 
                SET OBJECT_TYPE = (
                    CASE
                        WHEN (SELECT CONTACT.PERSON_ID from CONTACT where CONTACT.CONTACTID = ADDRESS.CONTACT_ID) IS NULL 
                            THEN 'Organisation'
                        ELSE 'Person'
                        END);
            UPDATE ADDRESS SET OBJECT_ROWID = CONTACT_ID;
        </sql>
        <dropIndex tableName="ADDRESS" indexName="IDX_ADDRESS_CONTACT_ID"/>
        <dropColumn tableName="ADDRESS">
            <column name="CONTACT_ID"/>
        </dropColumn>
        <addNotNullConstraint tableName="ADDRESS" columnName="OBJECT_ROWID" columnDataType="CHAR(36)"/>
        <addNotNullConstraint tableName="ADDRESS" columnName="OBJECT_TYPE" columnDataType="VARCHAR(63)"/>
  </changeSet>
</databaseChangeLog>
