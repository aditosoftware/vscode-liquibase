<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="p.neub" id="99a90986-a94f-4b97-88c3-08a0c9469e88">
        <!--add columns to district contact-->
        <addColumn tableName="DISTRICTCONTACT">
            <column name="VISIT_STARTDATE" type="DATETIME"/>
            <column name="VISIT_BEGIN_TIME" type="TIME"/>
            <column name="VISIT_END_TIME" type="TIME"/>
            <column name="RULE_ACTIVE" type="TINYINT"/>
        </addColumn>
    </changeSet>
    <!--change status data type of district contact-->
    <changeSet dbms="derby" author="p.neub" id="e6934b0b-17b5-4e95-945e-a8d25b4f3fb2">
        <sql>
            ALTER TABLE DISTRICTCONTACT ADD COLUMN STATUS_NEW VARCHAR(36);
            UPDATE DISTRICTCONTACT SET STATUS_NEW=STATUS;
            ALTER TABLE DISTRICTCONTACT DROP COLUMN STATUS;
            RENAME COLUMN DISTRICTCONTACT.STATUS_NEW TO STATUS;
        </sql>
    </changeSet>
    <changeSet dbms="!derby" author="p.neub" id="b24a89f4-b827-4329-b4c3-dc83a4b98c98">
        <modifyDataType tableName="DISTRICTCONTACT" columnName="STATUS" newDataType="VARCHAR(36)"/>
    </changeSet>
</databaseChangeLog>