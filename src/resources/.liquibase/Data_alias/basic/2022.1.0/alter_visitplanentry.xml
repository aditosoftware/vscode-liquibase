<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="p.neub" id="057fd7ba-b6f6-4f4c-883e-ccf69ded5371">
        <addColumn tableName="VISITPLANENTRY">
            <column name="PRIORITY" type="VARCHAR(36)"/>
            <column name="SOURCE" type="VARCHAR(36)"/>
            <column name="RESPONSIBLE_CONTACT_ID" type="CHAR(36)"/>
            <column name="INFO" type="NCLOB"/>
            <column name="DISTRICTCONTACT_ID" type="CHAR(36)"/>
            <column name="USER_NEW" type="NVARCHAR(50)"/>
            <column name="USER_EDIT" type="NVARCHAR(50)"/>
            <column name="DATE_NEW" type="DATETIME"/>
            <column name="DATE_EDIT" type="DATETIME" />
            <column name="FOLLOW_UP_APPOINTMENT_1" type="DATETIME"/>
            <column name="FOLLOW_UP_APPOINTMENT_2" type="DATETIME"/>
            <column name="VISITFREQUENCY" type="VARCHAR(36)"/>
            <column name="STARTDATE" type="DATETIME"/>
            <column name="ADVISER_ROLE" type="VARCHAR(36)"/>
        </addColumn>
        
        <dropIndex tableName="VISITPLANENTRY" indexName="IDX_VISITPLNENTRY_CONTCT_ID"/>
        <dropIndex tableName="VISITPLANENTRY" indexName="IDX_VISITPLNENTRY_VRECOMMND_ID"/>
        
        <renameColumn
            columnDataType="CHAR(36)"
            newColumnName="PERSON_CONTACT_ID"
            oldColumnName="CONTACT_ID"
            tableName="VISITPLANENTRY"/>  
        <renameColumn
            columnDataType="DATETIME"
            newColumnName="VISIT_DATE"
            oldColumnName="ENTRYDATE"
            tableName="VISITPLANENTRY"/> 
        <renameColumn
            columnDataType="CHAR(36)"
            newColumnName="VISITPLAN_ID"
            oldColumnName="VISITRECOMMENDATION_ID"
            tableName="VISITPLANENTRY"/>
        
        <createIndex tableName="VISITPLANENTRY" indexName="IDX_VISITPLNENT_PERS_CONTACT_ID">
            <column name="PERSON_CONTACT_ID"/>
        </createIndex>
        <createIndex tableName="VISITPLANENTRY" indexName="IDX_VISITPLANENTRY_VISITPLAN_ID">
            <column name="VISITPLAN_ID"/>
        </createIndex>
        
        <createIndex tableName="VISITPLANENTRY" indexName="IDX_VISITPLNENT_RESP_CONTACT_ID">
            <column name="RESPONSIBLE_CONTACT_ID"/>
        </createIndex>
        <createIndex tableName="VISITPLANENTRY" indexName="IDX_VISITPLNENT_DISTCONTACT_ID">
            <column name="DISTRICTCONTACT_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>