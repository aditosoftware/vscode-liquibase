<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="m.wachsmuth" id="8e3b9e98-1fb4-4dfb-85c4-d507760b69ba">
        <createTable tableName="RECEIPT">
            <column name="RECEIPTID" type="CHAR(36)">
                <constraints primaryKey="true" primaryKeyName="PK_RECEIPTID"/>
            </column>
            <column name="EXPENSES_ID" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="REMARK" type="LONGTEXT"/>
            <column name="COMPANYCARD" type="TINYINT">
                <constraints nullable="false"/>
            </column>
            <column name="RECEIPTDATE" type="DATETIME"/>
            <column name="CURRENCYRATE_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="AMOUNT" type="NUMERIC(14,2)">
                <constraints nullable="false"/>
            </column>
            <column name="TYPE" type="VARCHAR(36)"/>               
            <column name="USER_NEW" type="NVARCHAR(50)"/>
            <column name="USER_EDIT" type="NVARCHAR(50)"/>
            <column name="DATE_NEW" type="DATETIME"/>
            <column name="DATE_EDIT" type="DATETIME"/>
        </createTable>  
        <createIndex tableName="RECEIPT" indexName="IDX_RECEIPT_EXPENSES_ID">
            <column name="EXPENSES_ID"/>
        </createIndex>
        <createIndex tableName="RECEIPT" indexName="IDX_RECEIPT_CURRENCYRATE_ID">
            <column name="CURRENCYRATE_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>