<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="m.wachsmuth" id="dbce6db9-722c-4a15-8fd7-cca026ede58f">
        <createTable tableName="ABSENCE">
            <column name="ABSENCEID" type="CHAR(36)">
                <constraints primaryKey="true" primaryKeyName="PK_ABSENCEID"/>
            </column>
            <column name="EXPENSES_ID" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CONTACT_ID" type="CHAR(36)"/>           
            <column name="ENTRYDATE" type="DATETIME"/>
            <column name="KM" type="SMALLINT"/>
            <column name="BEDANDBREAKFAST" type="TINYINT" />
            <column name="LUNCH" type="TINYINT" />
            <column name="DINNER" type="TINYINT" />
            <column name="COUNTRY" type="VARCHAR(36)" />
            <column name="REMARK" type="LONGTEXT" />
            <column name="ALLOWANCETYPE" type="VARCHAR(36)" />
            <column name="ALLOWANCE" type="NUMERIC(14,2)" />
            <column name="USER_NEW" type="NVARCHAR(50)"/>
            <column name="USER_EDIT" type="NVARCHAR(50)"/>
            <column name="DATE_NEW" type="DATETIME"/>
            <column name="DATE_EDIT" type="DATETIME"/>
        </createTable>  
        <createIndex tableName="ABSENCE" indexName="IDX_ABSENCE_EXPENSES_ID">
            <column name="EXPENSES_ID"/>
        </createIndex>
        <createIndex tableName="ABSENCE" indexName="IDX_ABSENCE_CONTACT_ID">
            <column name="CONTACT_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>