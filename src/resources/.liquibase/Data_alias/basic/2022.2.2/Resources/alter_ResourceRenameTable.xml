<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="b.ulrich" id="d130bae6-a7bf-45f5-bce4-25cec8c9c01b" dbms="!oracle">
        <dropIndex indexName="IDX_RESOURCE_OBJECT_TYPE"
            tableName="RESOURCE"/>
        <dropIndex indexName="IDX_RESOURCE_OBJECT_ROWID"
            tableName="RESOURCE"/>
        <renameTable
            newTableName="RESOURCES"  
            oldTableName="RESOURCE"/> 
        <dropPrimaryKey constraintName="PK_RESOURCEID"  
            dropIndex="true" 
            tableName="RESOURCES"/>
        <renameColumn
            columnDataType="CHAR(36)"
            newColumnName="RESOURCESID"
            oldColumnName="RESOURCEID"
            tableName="RESOURCES"/>
        <addPrimaryKey tableName="RESOURCES"
            columnNames="RESOURCESID" constraintName="PK_RESOURCESID"/>
        <createIndex tableName="RESOURCES" indexName="IDX_RESOURCES_OBJECT_TYPE">
            <column name="OBJECT_TYPE"/>
        </createIndex>
        <createIndex tableName="RESOURCES" indexName="IDX_RESOURCES_OBJECT_ROWID">
            <column name="OBJECT_ROWID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>