            columnName="OBJECT_TYPE"
            columnDataType="NVARCHAR(63)"/>
        
        <renameTable oldTableName="SALESPROJECT_MEMBER" newTableName="OBJECTMEMBER"/>
        
    </changeSet>
</databaseChangeLog>