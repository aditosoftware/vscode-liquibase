        <update tableName="SALESPROJECT_MEMBER">
            <column name="OBJECT_TYPE" value="Salesproject" />
            <where>OBJECT_ROWID = '0833465c-8851-4fbb-b7e3-8c1d73c903da'</where>
        </update>
        
        <addNotNullConstraint
