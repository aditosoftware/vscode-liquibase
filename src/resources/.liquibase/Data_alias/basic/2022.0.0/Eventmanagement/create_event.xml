<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
  <changeSet author="m.groppe" id="5823ec4d-dd3f-4017-bc52-d5584e78281f">
    <createTable tableName="EVENT">
      <column name="EVENTID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column name="NAME" type="VARCHAR(50)"/>
      <column name="EMPLOYEE_CONTACT_ID" type="CHAR(36)"/>
      <column name="DESCRIPTION" type="VARCHAR(500)" />
      <column name="USER_NEW" type="VARCHAR(50)"/>
      <column name="DATE_NEW" type="datetime"/>
      <column name="USER_EDIT" type="VARCHAR(50)" />
      <column name="DATE_EDIT" type="datetime"/>
      <column name="STATUS" type="VARCHAR(36)"/>
      <column name="TYPE" type="VARCHAR(36)" />
      <column name="EVENTCODE" type="INT" />
      <column name="EVENT_BEGIN" type="datetime" />
      <column name="EVENT_END" type="datetime" />
      <column name="REGISTRATION_DEADLINE" type="datetime" />
      <column name="LOCATION" type="VARCHAR(250)" />
      <column name="EVENTTYPE" type="VARCHAR(36)" />
      <column name="MAXPARTICIPANTS" type="INTEGER"/>
    </createTable>
    <createIndex indexName="IDX_EVENTCODE" tableName="EVENT">
      <column defaultValueComputed="NULL" name="EVENTCODE" />
    </createIndex>
    <createIndex indexName="IDX_EVENT_EMPL_CONTACT_ID" tableName="EVENT">
      <column name="EMPLOYEE_CONTACT_ID" />
    </createIndex>
  </changeSet>
</databaseChangeLog>
