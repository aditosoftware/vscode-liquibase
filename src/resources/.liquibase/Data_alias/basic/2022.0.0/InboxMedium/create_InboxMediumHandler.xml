<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="v.broens" id="fca9bd62-f57e-4fa8-889c-e645d7a6430e">
        <createTable tableName="INBOXMEDIUMHANDLER">
            <column name="INBOXMEDIUMHANDLERID" type="CHAR(36)">
                <constraints  primaryKey="true" primaryKeyName="PK_INBOXMEDIUMHANDLERID"/>
            </column>
            <column name="NAME" type="NVARCHAR(50)"/>
            <column name="SENDERMAILADDRESS" type="NVARCHAR(254)"/>
            <column name="INBOX_ID" type="CHAR(36)"/>
            <column name="MEDIUM" type="NVARCHAR(36)"/>
            <column name="TICKETTEMPLATE_ID" type="CHAR(36)"/>
            <column name="NUMBERMATCHING" type="TINYINT"/>
            <column name="DATE_NEW" type="DATETIME"/>
            <column name="DATE_EDIT" type="DATETIME"/>
            <column name="USER_NEW" type="NVARCHAR(50)"/>
            <column name="USER_EDIT" type="NVARCHAR(50)"/>
        </createTable>
        <createIndex tableName="INBOXMEDIUMHANDLER" indexName="IDX_INBOXMED_INBOX_ID">
            <column name="INBOX_ID"/>
        </createIndex>
        <createIndex tableName="INBOXMEDIUMHANDLER" indexName="IDX_INBOXMED_TEMPL_ID">
            <column name="TICKETTEMPLATE_ID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>