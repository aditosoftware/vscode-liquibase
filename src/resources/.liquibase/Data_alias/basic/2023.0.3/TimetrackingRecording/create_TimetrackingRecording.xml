<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
    <changeSet author="b.ulrich" id="dcb57341-900c-4ab0-9e56-5767f71572e1">
        <preConditions onFail="MARK_RAN">
          <not>
            <tableExists tableName="TIMETRACKINGRECORDING" />
          </not>
        </preConditions>
        <createTable tableName="TIMETRACKINGRECORDING">
            <column name="TIMETRACKINGRECORDINGID" type="CHAR(36)">
                <constraints primaryKey="true" primaryKeyName="PK_TIMETRACKINGRECORDINGID"/>
            </column>
            <column name="OBJECT_TYPE" type="NVARCHAR(63)">
                <constraints nullable="false"/>
            </column>
            <column name="OBJECT_ROWID" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="ENTRYDATE" type="DATETIME" />
        </createTable>
            
        <createIndex tableName="TIMETRACKINGRECORDING" indexName="IDX_TIMETRACKINGREC_OBJTYPE">
            <column name="OBJECT_TYPE"/>
        </createIndex>
        <createIndex tableName="TIMETRACKINGRECORDING" indexName="IDX_TIMETRACKINGREC_OBJROWID">
            <column name="OBJECT_ROWID"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>