<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="M.Wachsmuth" id="25c0f5a8-df40-4cad-8004-66cea505abe3">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="QUESTIONNAIREANSWER" />
      </not>
    </preConditions>
    <createTable tableName="QUESTIONNAIREANSWER">
      <column name="QUESTIONNAIREANSWERID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column name="QUESTIONNAIREQUESTION_ID" type="char(36)" />
      <column name="QUESTIONNAIREPARTICIPANT_ID" type="char(36)" />
      <column name="TEXT" type="NCLOB" />
      <column name="VALUE" type="NVARCHAR(255)" />
      <column name="VALUE_NUMBER" type="DECIMAL(15, 2)"/>
      <column name="FOREIGNKEYTYPE" type="VARCHAR(100)" />
      <column name="FOREIGNKEY" type="VARCHAR(100)" />
      <column defaultValueComputed="NULL" name="DATE_EDIT" type="datetime" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
    </createTable>
    <modifySql dbms="mysql,mariadb">
            <regExpReplace replace="NVARCHAR\(([^\)]*)\)" with="VARCHAR($1) CHARACTER SET utf8mb4" />
            <replace replace="LONGTEXT CHARACTER SET utf8" with="LONGTEXT CHARACTER SET utf8mb4" />
    </modifySql>
  </changeSet>
  <changeSet author="M.Wachsmuth" id="9f4c5fe6-b96d-4062-b121-9a40f63d658a">
    <createIndex indexName="QUESTIONNAIREQUESTION_ANSWER_ID_IDX" tableName="QUESTIONNAIREANSWER">
      <column name="QUESTIONNAIREQUESTION_ID" />
    </createIndex>
  </changeSet>
  <changeSet author="M.Wachsmuth" id="088300b1-4327-4d12-b3ea-85b184f373af">
    <createIndex indexName="QUESTIONNAIREPARTICIPANT_ANSWER_ID_IDX" tableName="QUESTIONNAIREANSWER">
      <column name="QUESTIONNAIREPARTICIPANT_ID" />
    </createIndex>
  </changeSet>
</databaseChangeLog>