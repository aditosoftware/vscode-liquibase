<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="M.Wachmsuth" id="f8aaef58-66c4-46c4-b5be-d501c77bc021">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="QUESTIONNAIRE" />
      </not>
    </preConditions>
    <createTable tableName="QUESTIONNAIRE">
      <column name="QUESTIONNAIREID" type="CHAR(36)">
        <constraints nullable="false" primaryKey="true" />
      </column>
      <column name="DOCUMENTTEMPLATE_ID" type="CHAR(36)"/>
      <column name="TYPE" type="VARCHAR(36)" />
      <column name="NAME" type="VARCHAR(100)" />
      <column name="DESCRIPTION" type="NVARCHAR(255)" />
      <column name="SURVEYDESCRIPTIONPAGE" type="NCLOB" />
      <column name="COMPLETEBUTTONTEXT" type="NVARCHAR(255)" />
      <column name="COMPLETIONPAGETEXT" type="NVARCHAR(255)" />
      <column name="ISANONYM" type="TINYINT" />
      <column name="SHOWPROGRESSBAR" type="TINYINT" />
      <column name="SHOWQUESTIONNUMBERS" type ="TINYINT"/>
      <column name="ALLOWMULTISUBMISSIONS" type="TINYINT" />
      <column name="FOREIGNKEYTYPE" type="VARCHAR(100)" />
      <column name="FOREIGNKEY" type="VARCHAR(100)" />
      <column name="QUESTIONNAIRESTARTDATE" type="datetime" />
      <column name="QUESTIONNAIREENDDATE" type="datetime" />
      <column name="STATUS" type="VARCHAR(36)" />
      <column name="FORMTITLE" type="NVARCHAR(100)" />
      <column name="FORMSUBTITLE" type="NVARCHAR(255)" />
      <column name="DEFAULTLANGUAGE" type="CHAR(3)" />
      <column name="LOGOURL" type="VARCHAR(255)" />
      <column name="WORKFLOW" type="VARCHAR(255)" />
      <column defaultValueComputed="NULL" name="DATE_EDIT" type="datetime" />
      <column name="USER_EDIT" type="VARCHAR(63)" />
      <column defaultValueComputed="NULL" name="DATE_NEW" type="datetime" />
      <column name="USER_NEW" type="VARCHAR(63)" />
    </createTable>
    <modifySql dbms="mysql,mariadb">
            <regExpReplace replace="NVARCHAR\(([^\)]*)\)" with="VARCHAR($1) CHARACTER SET utf8mb4" />
            <replace replace="LONGTEXT CHARACTER SET utf8" with="LONGTEXT CHARACTER SET utf8mb4" />
    </modifySql>
  </changeSet>
</databaseChangeLog>