<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">
  <changeSet author="s.listl" id="33cd199b-56cb-4015-a5bb-c742bb6904d1">
      <preConditions onFail="MARK_RAN">
          <not>
              <tableExists tableName="ASYS_ICONS"/>
          </not>
      </preConditions>
      <createTable tableName="ASYS_ICONS">
          <column name="ID" type="CHAR(36)">
              <constraints nullable="false" primaryKey="true" primaryKeyName="PK_ASYS_ICONS_ID"/>
          </column>
          <column name="DATE_EDIT" type="DATETIME"/>
          <column name="DATE_NEW" type="DATETIME"/>
          <column name="USER_EDIT" type="VARCHAR(63)"/>
          <column name="USER_NEW" type="VARCHAR(63)"/>
          <column name="BINDATA" type="LONGBLOB"/>
          <column name="DESCRIPTION" type="NVARCHAR(127)"/>
          <column name="ICON_TYPE" type="VARCHAR(255)"/>
      </createTable>
  </changeSet>
</databaseChangeLog>